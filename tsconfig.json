{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "typeRoots": [
      "./dts",
      "./node_modules/@types"
    ]
  },
  "include": [
    "./dts/global.d.ts",
    "scripts"
  ],
  "exclude": [
    "node_modules"
  ]
}